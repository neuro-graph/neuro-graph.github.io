@prefix ng: <https://neuro-graph.dev/ontology#> .
@prefix ex: <https://neuro-graph.dev/example#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ng:RetailOntology a owl:Ontology ;
  rdfs:label "Retail Ontology" ;
  rdfs:comment "A small OWL ontology for visualizing customers, orders, products, payments, and addresses." .

ng:BusinessEntity a owl:Class ;
  rdfs:label "Business Entity" ;
  rdfs:comment "A root type for business objects in the graph." .

ng:Customer a owl:Class ;
  rdfs:subClassOf ng:BusinessEntity ;
  rdfs:label "Customer" ;
  rdfs:comment "A person or organization that buys products." .

ng:Order a owl:Class ;
  rdfs:subClassOf ng:BusinessEntity ;
  rdfs:label "Order" ;
  rdfs:comment "A purchase request created by a customer." .

ng:Product a owl:Class ;
  rdfs:subClassOf ng:BusinessEntity ;
  rdfs:label "Product" ;
  rdfs:comment "An item that can be ordered." .

ng:Payment a owl:Class ;
  rdfs:label "Payment" ;
  rdfs:comment "A transaction used to pay for an order." .

ng:Address a owl:Class ;
  rdfs:label "Address" ;
  rdfs:comment "A physical or delivery address." .

ng:placesOrder a owl:ObjectProperty ;
  rdfs:label "places order" ;
  rdfs:comment "Connects a customer to an order." ;
  rdfs:domain ng:Customer ;
  rdfs:range ng:Order .

ng:containsProduct a owl:ObjectProperty ;
  rdfs:label "contains product" ;
  rdfs:comment "Connects an order to a product." ;
  rdfs:domain ng:Order ;
  rdfs:range ng:Product .

ng:paidBy a owl:ObjectProperty ;
  rdfs:label "paid by" ;
  rdfs:domain ng:Order ;
  rdfs:range ng:Payment .

ng:shipsTo a owl:ObjectProperty ;
  rdfs:label "ships to" ;
  rdfs:domain ng:Order ;
  rdfs:range ng:Address .

ng:customerName a owl:DatatypeProperty ;
  rdfs:label "customer name" ;
  rdfs:domain ng:Customer ;
  rdfs:range xsd:string .

ng:orderTotal a owl:DatatypeProperty ;
  rdfs:label "order total" ;
  rdfs:domain ng:Order ;
  rdfs:range xsd:decimal .

ex:customer-1000 a owl:NamedIndividual, ng:Customer ;
  rdfs:label "Amina Khan" ;
  rdfs:comment "A sample customer used by the Neuro Graph demo." ;
  ng:placesOrder ex:order-4501 .

ex:order-4501 a owl:NamedIndividual, ng:Order ;
  rdfs:label "Order 4501" ;
  ng:containsProduct ex:product-graphdb ;
  ng:paidBy ex:payment-7788 ;
  ng:shipsTo ex:address-berlin ;
  ng:orderTotal "129.99"^^xsd:decimal .

ex:product-graphdb a owl:NamedIndividual, ng:Product ;
  rdfs:label "Graph Database Starter Kit" .

ex:payment-7788 a owl:NamedIndividual, ng:Payment ;
  rdfs:label "Credit Card Payment" .

ex:address-berlin a owl:NamedIndividual, ng:Address ;
  rdfs:label "Berlin Delivery Address" .
